# Stage 1: AOT publish for Alpine (musl).
# gcompat provides a glibc compatibility layer so Grpc.Tools' glibc protoc binary runs on musl.
FROM mcr.microsoft.com/dotnet/sdk:10.0-alpine AS build

RUN apk add --no-cache clang gcc build-base zlib-dev musl-dev gcompat

WORKDIR /src
COPY BeyondTrust.SecretSafeProvider/ ./BeyondTrust.SecretSafeProvider/

RUN dotnet publish BeyondTrust.SecretSafeProvider/BeyondTrust.SecretSafeProvider.csproj \
    -c Release \
    -r linux-musl-x64 \
    -p:StaticExecutable=false \
    -o /publish

# Stage 2: run terraform plan against the provider
FROM hashicorp/terraform:latest

# Provider binary
COPY --from=build /publish/terraform-provider-secretsafe /providers/terraform-provider-secretsafe
RUN chmod +x /providers/terraform-provider-secretsafe

# Configure dev_overrides so terraform uses the local binary instead of the registry
RUN printf 'provider_installation {\n  dev_overrides {\n    "beyondtrust/secretsafe" = "/providers"\n  }\n  direct {}\n}\n' \
    > /root/.terraformrc

# Terraform configuration
COPY terraform/ /workspace/
WORKDIR /workspace

# ENTRYPOINT ["/providers/terraform-provider-secretsafe"]

ENTRYPOINT ["terraform", "plan"]
